---
import BaseLayout from './BaseLayout.astro';
import CtaButtons from '../components/CtaButtons.astro';
import '../styles/blog.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  category: string;
  categoryLabel: string;
  tags: string[];
  targetLang?: string;
  targetLangName?: string;
  targetLangSlug?: string;
  locale: string;
  uiLang: string;
  slug: string;
  translations: Record<string, string>;
  uiLanguages: Array<{ code: string; nativeName: string; flag: string; url: string }>;
  hreflangAlternates: Array<{ lang: string; url: string }>;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  category,
  categoryLabel,
  tags,
  targetLang,
  targetLangName,
  targetLangSlug,
  locale,
  uiLang,
  slug,
  translations,
  uiLanguages,
  hreflangAlternates,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const blogTitle = translations['blog_title'] ?? 'Blog';
const backText = translations['blog_back_to_blog'] ?? 'Back to blog';
const ctaTitle = translations['blog_cta_title'] ?? 'Ready to start reading?';
const ctaSubtitle = translations['blog_cta_subtitle'] ?? 'Download Lingo7 and begin your language learning journey today.';
const learnCta = targetLangName
  ? (translations['blog_related_learn'] ?? 'Start learning {targetLang} now').replace('{targetLang}', targetLangName)
  : null;

const canonicalUrl = `https://lingoseven.com/${uiLang}/blog/${slug}/`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    datePublished: pubDate.toISOString(),
    ...(updatedDate && { dateModified: updatedDate.toISOString() }),
    author: {
      '@type': 'Organization',
      name: 'Lingo7',
      url: 'https://lingoseven.com',
    },
    publisher: {
      '@type': 'Organization',
      name: 'Lingo7',
      logo: {
        '@type': 'ImageObject',
        url: 'https://lingoseven.com/images/logo.svg',
      },
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': canonicalUrl,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: 'https://lingoseven.com',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: blogTitle,
        item: `https://lingoseven.com/${uiLang}/blog/`,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: title,
      },
    ],
  },
];

const ogArticle = {
  publishedTime: pubDate.toISOString(),
  ...(updatedDate && { modifiedTime: updatedDate.toISOString() }),
  author,
  section: categoryLabel,
  tags,
};
---

<BaseLayout
  title={title}
  description={description}
  lang={uiLang}
  canonicalUrl={canonicalUrl}
  ogType="article"
  ogArticle={ogArticle}
  hreflangAlternates={hreflangAlternates}
  jsonLd={jsonLd}
  translations={translations}
  uiLang={uiLang}
  uiLanguages={uiLanguages}
  blogUrl={`/${uiLang}/blog/`}
>
  <main class="article-container">
    <header class="article-header">
      <nav class="article-breadcrumb">
        <a href="/">Home</a>
        <span class="article-breadcrumb-sep">/</span>
        <a href={`/${uiLang}/blog/`}>{blogTitle}</a>
        <span class="article-breadcrumb-sep">/</span>
        <span>{title}</span>
      </nav>

      <div class="article-meta">
        <span class="article-category">{categoryLabel}</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      </div>

      <h1>{title}</h1>
      <p class="article-description">{description}</p>
    </header>

    <article class="prose">
      <slot />
    </article>

    <div class="article-cta">
      <h3>{ctaTitle}</h3>
      <p>{ctaSubtitle}</p>
      <div class="article-cta-buttons">
        {learnCta && targetLangSlug && (
          <a href={`/${uiLang}/learn/${targetLangSlug}/`} class="article-cta-learn">
            {learnCta}
          </a>
        )}
      </div>
      <div style="margin-top: 16px;">
        <CtaButtons />
      </div>
    </div>
  </main>
</BaseLayout>
