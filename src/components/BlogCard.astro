---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  categoryLabel: string;
  slug: string;
  uiLang: string;
  targetLangFlag?: string;
  readMoreText: string;
}

const { title, description, pubDate, category, categoryLabel, slug, uiLang, targetLangFlag, readMoreText } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/${uiLang}/blog/${slug}/`} class="blog-card" data-category={category}>
  <div class="blog-card-body">
    <div class="blog-card-meta">
      <span class="blog-card-category">{categoryLabel}</span>
      <span>{formattedDate}</span>
    </div>
    <h2 class="blog-card-title">{title}</h2>
    <p class="blog-card-description">{description}</p>
  </div>
  <div class="blog-card-footer">
    <span class="blog-card-read-more">{readMoreText} &rarr;</span>
    {targetLangFlag && <span class="blog-card-lang-flag">{targetLangFlag}</span>}
  </div>
</a>
