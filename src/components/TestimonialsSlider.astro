---

<!-- Reviews -->
<section id="testimonials" class="testimonials">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">{t('testimonials_tag')}</span>
            <h2>{t('testimonials_title')}</h2>
            <p>{t('testimonials_subtitle')}</p>
        </div>
    </div>
    <div class="testimonials-slider">
        <div class="testimonials-track">
            {testimonials.map((tm) => (
                <div class="testimonial-card">
                    <div class="stars">★★★★★</div>
                    <p>"{t(`testimonial_${tm.id}`)}"</p>
                    <div class="testimonial-author">
                        <span class={`fi fi-${tm.flag}`}></span>
                        <div class="author-info">
                            <span class="author-name">{tm.name}</span>
                            {tm.level && <span class="author-level">{t(`level_${tm.level}`)}</span>}
                        </div>
                    </div>
                </div>
            ))}
        </div>
        <button class="testimonials-btn testimonials-btn-prev" aria-label="Previous">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 18l-6-6 6-6"/>
            </svg>
        </button>
        <button class="testimonials-btn testimonials-btn-next" aria-label="Next">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 18l6-6-6-6"/>
            </svg>
        </button>
    </div>
</section>
