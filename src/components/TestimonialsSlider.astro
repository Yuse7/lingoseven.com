---
interface Props {
  targetLangName?: string;
  translations?: Record<string, any>;
}
const { targetLangName = '', translations = {} } = Astro.props;

function t(key: string): string {
  const val = translations[key] || key;
  return val.replace(/{targetLang}/g, targetLangName);
}

type Testimonial = { id: number; flag: string; name: string; level?: 'beginner' | 'intermediate' | 'advanced' };

const testimonials: Testimonial[] = [
  { id: 1, flag: 'it', name: 'Luca Conti' },
  { id: 2, flag: 'gb', name: 'Emily Carter' },
  { id: 3, flag: 'fr', name: 'Hugo Bernard' },
  { id: 4, flag: 'es', name: 'Carlos Hernández' },
  { id: 5, flag: 'gb', name: 'Alice Green', level: 'advanced' },
  { id: 6, flag: 'it', name: 'Giulia Bianchi' },
  { id: 7, flag: 'gb', name: 'Emma Thompson', level: 'beginner' },
  { id: 8, flag: 'fr', name: 'Chloé Martin' },
  { id: 9, flag: 'de', name: 'Jonas Weber' },
  { id: 10, flag: 'es', name: 'Diego Castillo' },
  { id: 11, flag: 'gb', name: 'James Miller' },
  { id: 12, flag: 'de', name: 'Leon Müller', level: 'intermediate' },
  { id: 13, flag: 'es', name: 'Valeria Navarro' },
  { id: 14, flag: 'fr', name: 'Thomas Moreau' },
  { id: 15, flag: 'gb', name: 'Olivia Bennett' },
  { id: 16, flag: 'fr', name: 'Camille Dubois' },
  { id: 17, flag: 'es', name: 'Martina Ruiz' },
  { id: 18, flag: 'gb', name: 'Sarah Johnson' },
  { id: 19, flag: 'it', name: 'Francesca Romano', level: 'advanced' },
  { id: 20, flag: 'gb', name: 'Daniel White' },
