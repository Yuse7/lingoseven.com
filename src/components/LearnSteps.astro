---
interface Props {
  targetLangName: string;
  translations: Record<string, any>;
}
const { targetLangName, translations } = Astro.props;

function t(key: string): string {
  const val = translations[key] || key;
  return val.replace(/{targetLang}/g, targetLangName);
}

const steps = [
  { number: '1', titleKey: 'step1_title', descKey: 'step1_desc' },
  { number: '2', titleKey: 'step2_title', descKey: 'step2_desc' },
  { number: '3', titleKey: 'step3_title', descKey: 'step3_desc' },
];
---

<section class="learn-steps">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">{t('steps_tag')}</span>
      <h2>{t('steps_title')}</h2>
      <p>{t('steps_subtitle')}</p>
    </div>
    <div class="learn-steps-list">
      {steps.map((step) => (
        <div class="learn-step-card">
          <div class="learn-step-number">{step.number}</div>
          <div class="learn-step-content">
            <h3>{t(step.titleKey)}</h3>
            <p>{t(step.descKey)}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
