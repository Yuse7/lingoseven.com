---
interface UiLanguage {
  code: string;
  nativeName: string;
  flag: string;
  url: string;
}

interface Props {
  translations?: Record<string, string>;
  uiLang?: string;
  uiLanguages?: UiLanguage[];
  showNav?: boolean;
  blogUrl?: string;
}

const { translations, uiLang = 'en', uiLanguages, showNav = false, blogUrl } = Astro.props;
const blogLabel = translations?.['blog_nav'] ?? 'Blog';

const navFeatures = translations?.['nav_features'] ?? 'Features';
const navHowItWorks = translations?.['nav_how_it_works'] ?? 'How it works';
const navReviews = translations?.['nav_reviews'] ?? 'Reviews';
const navFaq = translations?.['nav_faq'] ?? 'FAQ';

const currentLang = uiLanguages?.find((l) => l.code === uiLang);
---

<header class="header">
  <nav class="nav container">
    <a href="/" class="logo">
      <img src="/images/logo.svg" alt="Lingo7" class="logo-img" />
    </a>

    {showNav && (
      <ul class="nav-links">
        <li><a href="#features">{navFeatures}</a></li>
        <li><a href="#how-it-works">{navHowItWorks}</a></li>
        <li><a href="#testimonials">{navReviews}</a></li>
        <li><a href="#faq">{navFaq}</a></li>
      </ul>
    )}

    {blogUrl && (
      <a href={blogUrl} class="header-blog-link">{blogLabel}</a>
    )}

    <div class="header-actions">
      {uiLanguages && uiLanguages.length > 1 && (
        <div class="lang-switcher">
          <button class="lang-switcher-btn" aria-label="Switch language">
            <span class="lang-switcher-flag">{currentLang?.flag ?? '🌐'}</span>
            <span class="lang-switcher-name">{currentLang?.nativeName ?? 'English'}</span>
            <svg class="lang-switcher-arrow" width="12" height="12" viewBox="0 0 12 12" fill="currentColor">
              <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="lang-switcher-dropdown">
            {uiLanguages.map((lang) => (
              <a
                href={lang.url}
                class:list={['lang-switcher-option', { active: lang.code === uiLang }]}
              >
                <span class="lang-switcher-option-flag">{lang.flag}</span>
                <span>{lang.nativeName}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="header-store-buttons">
        <a
          href="https://apps.apple.com/app/id6471030440"
          class="store-btn store-btn-apple"
          aria-label="App Store"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
          </svg>
        </a>
        <a
          href="https://play.google.com/store/apps/details?id=com.doublereading"
          class="store-btn store-btn-google"
          aria-label="Google Play"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M3 20.5v-17c0-.59.34-1.11.84-1.35L13.69 12l-9.85 9.85c-.5-.24-.84-.76-.84-1.35m13.81-5.38L6.05 21.34l8.49-8.49 2.27 2.27m3.35-4.31c.34.27.56.69.56 1.19s-.22.92-.56 1.19l-2.11 1.24-2.5-2.5 2.5-2.5 2.11 1.38M6.05 2.66l10.76 6.22-2.27 2.27-8.49-8.49z" />
          </svg>
        </a>
      </div>
    </div>

    <button class="mobile-menu-btn" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
</header>

<style>
  .header-blog-link {
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .header-blog-link:hover {
    color: var(--primary);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .lang-switcher {
    position: relative;
  }

  .lang-switcher-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--background-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    cursor: pointer;
    font-size: 0.85rem;
    transition: border-color 0.2s;
  }

  .lang-switcher-btn:hover {
    border-color: var(--primary);
  }

  .lang-switcher-flag {
    font-size: 1.1rem;
    line-height: 1;
  }

  .lang-switcher-name {
    max-width: 100px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .lang-switcher-arrow {
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .lang-switcher.open .lang-switcher-arrow {
    transform: rotate(180deg);
  }

  .lang-switcher-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    min-width: 200px;
    max-height: 400px;
    overflow-y: auto;
    background: var(--background-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    z-index: 1000;
    padding: 4px;
  }

  .lang-switcher.open .lang-switcher-dropdown {
    display: block;
  }

  .lang-switcher-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    color: var(--text);
    text-decoration: none;
    font-size: 0.85rem;
    border-radius: calc(var(--radius) - 2px);
    transition: background 0.15s;
  }

  .lang-switcher-option:hover {
    background: rgba(74, 222, 128, 0.05);
  }

  .lang-switcher-option.active {
    background: rgba(74, 222, 128, 0.1);
    font-weight: 600;
  }

  .lang-switcher-option-flag {
    font-size: 1.1rem;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .lang-switcher-name {
      display: none;
    }

    .lang-switcher-btn {
      padding: 6px 8px;
    }

    .lang-switcher-dropdown {
      right: -40px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const switcher = document.querySelector('.lang-switcher');
    const btn = document.querySelector('.lang-switcher-btn');
    if (!switcher || !btn) return;

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      switcher.classList.toggle('open');
    });

    document.addEventListener('click', () => {
      switcher.classList.remove('open');
    });

    switcher.querySelector('.lang-switcher-dropdown')?.addEventListener('click', (e) => {
      e.stopPropagation();
    });
  });
</script>
