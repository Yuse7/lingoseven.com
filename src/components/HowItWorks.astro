---
interface Props {
  targetLangName?: string;
  translations?: Record<string, any>;
}
const { targetLangName = '', translations = {} } = Astro.props;

function t(key: string): string {
  const val = translations[key] || key;
  return val.replace(/{targetLang}/g, targetLangName);
}
---

<!-- How it works -->
<section id="how-it-works" class="how-it-works">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">{t('how_tag')}</span>
            <h2>{t('how_title')}</h2>
            <p>{t('how_subtitle')}</p>
        </div>
        <div class="steps-detailed">
            <div class="step-detailed">
                <div class="step-animation">
                    <video src="/videos/Read.mp4" class="step-video" autoplay muted playsinline id="readVideo"></video>
                    <span class="step-number-overlay" id="readNumber">1</span>
                </div>
                <div class="step-content">
                    <h3>{t('how_step1_title')}</h3>
                    <p class="step-description" set:html={t('how_step1_desc')}></p>
                    <div class="step-results">
                        <span class="result-label">{t('how_result_label')}</span>
                        <ul>
                            <li set:html={t('how_step1_result1')}></li>
                            <li set:html={t('how_step1_result2')}></li>
                            <li set:html={t('how_step1_result3')}></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="step-detailed">
                <div class="step-number">2</div>
                <div class="step-content">
                    <h3>{t('how_step2_title')}</h3>
                    <p class="step-description" set:html={t('how_step2_desc')}></p>
                    <div class="step-results">
                        <span class="result-label">{t('how_result_label')}</span>
                        <ul>
                            <li set:html={t('how_step2_result1')}></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="step-detailed">
                <div class="step-number">3</div>
                <div class="step-content">
                    <h3>{t('how_step3_title')}</h3>
                    <p class="step-description" set:html={t('how_step3_desc')}></p>
                    <div class="step-results">
                        <span class="result-label">{t('how_result_label')}</span>
                        <ul>
                            <li set:html={t('how_step3_result1')}></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="bonus-blocks">
            <div class="bonus-block">
                <div class="bonus-icon">🌱</div>
                <div class="bonus-content">
                    <h4>{t('how_bonus1_title')}</h4>
                    <p set:html={t('how_bonus1_desc')}></p>
                </div>
            </div>
            <div class="bonus-block">
                <div class="bonus-icon">🍒</div>
                <div class="bonus-content">
                    <h4>{t('how_bonus2_title')}</h4>
                    <p set:html={t('how_bonus2_desc')}></p>
                </div>
            </div>
        </div>

        <div class="summary-block">
            <div class="summary-pill">
                <span class="summary-pill-dot"></span>
                {t('how_summary_label')}
            </div>
            <p>{t('how_summary_text')}</p>
        </div>
    </div>
</section>
