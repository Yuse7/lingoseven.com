---
interface Props {
  targetLangName: string;
  translations: Record<string, any>;
}
const { targetLangName, translations } = Astro.props;

function t(key: string): string {
  const val = translations[key] || key;
  return val.replace(/{targetLang}/g, targetLangName);
}
---

<section class="hero hero-split">
  <div class="container">
    <div class="hero-split-content">
      <div class="hero-text">
        <div class="hero-pill">
          <span class="hero-pill-dot"></span>
          {t('learn_hero_pill')}
        </div>
        <h1 class="hero-title-modern">
          {t('hero_title')}
        </h1>
        <div class="hero-badges">
          <span class="hero-badge badge-green">{t('features_slider_tag')}</span>
          <span class="hero-badge badge-amber">{t('audio_tag')}</span>
          <span class="hero-badge badge-purple">{t('practice_tag')}</span>
        </div>
        <div class="hero-cta">
          <a href="https://apps.apple.com/app/id6471030440" class="btn btn-primary btn-large">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
            </svg>
            <div class="btn-text">
              <span class="btn-small">{t('download_on')}</span>
              <span class="btn-big">{t('app_store')}</span>
            </div>
          </a>
          <a href="https://play.google.com/store/apps/details?id=com.doublereading" class="btn btn-outline btn-large">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3 20.5v-17c0-.59.34-1.11.84-1.35L13.69 12l-9.85 9.85c-.5-.24-.84-.76-.84-1.35m13.81-5.38L6.05 21.34l8.49-8.49 2.27 2.27m3.35-4.31c.34.27.56.69.56 1.19s-.22.92-.56 1.19l-2.11 1.24-2.5-2.5 2.5-2.5 2.11 1.38M6.05 2.66l10.76 6.22-2.27 2.27-8.49-8.49z" />
            </svg>
            <div class="btn-text">
              <span class="btn-small">{t('get_it_on')}</span>
              <span class="btn-big">{t('google_play')}</span>
            </div>
          </a>
        </div>
      </div>
      <div class="hero-image">
        <img src="/images/pic.png" alt="App mascot" class="hero-mascot-split">
      </div>
    </div>
  </div>
</section>

<style>
  .hero-badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 12px;
    margin-bottom: 20px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .hero-badge::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .badge-purple {
    background: rgba(99, 102, 241, 0.15);
    color: #a5b4fc;
  }

  .badge-purple::before {
    background: #a5b4fc;
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
  }

  .badge-amber {
    background: rgba(251, 191, 36, 0.15);
    color: #fcd34d;
  }

  .badge-amber::before {
    background: #fcd34d;
    box-shadow: 0 0 0 4px rgba(251, 191, 36, 0.15);
  }

  .badge-green {
    background: rgba(74, 222, 128, 0.15);
    color: #4ade80;
  }

  .badge-green::before {
    background: #4ade80;
    box-shadow: 0 0 0 4px rgba(74, 222, 128, 0.15);
  }

  @media (max-width: 768px) {
    .hero-badges {
      justify-content: center;
    }
    .hero-badge {
      font-size: 0.75rem;
      padding: 7px 14px;
    }
  }
</style>
