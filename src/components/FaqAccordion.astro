---
interface Props {
  targetLangName?: string;
  translations?: Record<string, any>;
}
const { targetLangName = '', translations = {} } = Astro.props;

function t(key: string): string {
  const val = translations[key] || key;
  return val.replace(/{targetLang}/g, targetLangName);
}

const items = [1, 2, 3, 4, 5];
---

<!-- Polyglot Secrets -->
<section id="faq" class="faq">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">{t('faq2_tag')}</span>
            <h2>{t('faq2_title')}</h2>
            <p>{t('faq2_subtitle')}</p>
        </div>
        <div class="faq-list">
            {items.map((i) => (
                <div class="faq-item">
                    <button class="faq-question">
                        <span>{t(`faq2_item${i}_question`)}</span>
                        <span class="faq-icon">+</span>
                    </button>
                    <div class="faq-answer">
                        <p set:html={t(`faq2_item${i}_principle`)}></p>
                        <p set:html={t(`faq2_item${i}_how`)}></p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
