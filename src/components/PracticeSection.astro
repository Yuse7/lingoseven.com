---
import { practiceWordByLang, practiceOptionsByUi, fallbackWord, fallbackOptions } from '../data/practiceExamples';

interface Props {
  targetLangName?: string;
  targetLang?: string;
  uiLang?: string;
  translations?: Record<string, any>;
}
const { targetLangName = '', targetLang = 'en', uiLang = 'en', translations = {} } = Astro.props;

function t(key: string): string {
  const val = translations[key] || key;
  return val.replace(/{targetLang}/g, targetLangName);
}

const word = practiceWordByLang[targetLang] ?? fallbackWord;
const opts = practiceOptionsByUi[uiLang] ?? fallbackOptions;
// 4 options: distractor, correct (selected), distractor, distractor
const optionList = [opts.distractors[0], opts.correct, opts.distractors[1], opts.distractors[2]];
const selectedIdx = 1;

// For "spell from letters": use lowercase chars of word.word
const wordLower = word.word.toLowerCase();
const wordChars = Array.from(wordLower);
const halfPoint = Math.ceil(wordChars.length / 2);
const usedChars = wordChars.slice(0, halfPoint);
const remainingChars = wordChars.slice(halfPoint);
const typedPrefix = usedChars.join('');
---

<!-- Spaced Repetition Practice -->
<section class="practice-section">
    <div class="container">
        <div class="practice-header">
            <span class="section-tag section-tag--purple">{t('practice_tag')}</span>
            <h2>{t('practice_title')}</h2>
            <p class="practice-subtitle">{t('practice_subtitle')}</p>
        </div>

        <div class="practice-layout">
            <!-- Exercise tabs -->
            <div class="exercise-tabs">
                <button class="ex-tab active" data-ex="0">
                    <svg class="ex-tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                    {t('practice_tab_choose')}
                </button>
                <button class="ex-tab" data-ex="1">
                    <svg class="ex-tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
                    {t('practice_tab_listen')}
                </button>
                <button class="ex-tab" data-ex="2">
                    <svg class="ex-tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="6" cy="12" r="3"/><circle cx="18" cy="12" r="3"/><circle cx="12" cy="6" r="3"/><circle cx="12" cy="18" r="3"/></svg>
                    {t('practice_tab_spell')}
                </button>
                <button class="ex-tab" data-ex="3">
                    <svg class="ex-tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 12l2 2 4-4"/><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>
                    {t('practice_tab_is_correct')}
                </button>
                <button class="ex-tab" data-ex="4">
                    <svg class="ex-tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>
                    {t('practice_tab_pronounce')}
                </button>
                <button class="ex-tab" data-ex="5">
                    <svg class="ex-tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                    {t('practice_tab_recall')}
                </button>
            </div>

            <!-- Phone mockup with exercise widgets -->
            <div class="phone-mockup">
                <div class="phone-bezel">
                    <!-- Progress bar -->
                    <div class="ex-progress">
                        <div class="ex-progress-text">{t('practice_progress_text')}</div>
                        <div class="ex-progress-bar"><div class="ex-progress-fill"></div></div>
                    </div>

                    <!-- Exercise panels -->
                    <div class="ex-panel active" data-panel="0">
                        <div class="ex-card ex-card-top">
                            <div class="ex-word-main">{word.word}</div>
                            <div class="ex-freq"><span class="freq-dot"></span><span class="freq-dot"></span><span class="freq-dot active"></span><span class="freq-dot active"></span><span class="freq-dot active"></span></div>
                        </div>
                        <div class="ex-card ex-card-bottom ex-card-teal">
                            <div class="ex-label">{t('practice_label_choose_translation')}</div>
                            <div class="ex-grid-2x2">
                                {optionList.map((opt, i) => (
                                    <div class={`ex-option${i === selectedIdx ? ' selected' : ''}`}>{opt}</div>
                                ))}
                            </div>
                        </div>
                        <div class="ex-action-btn ex-btn-teal">{t('practice_btn_check')}</div>
                    </div>

                    <div class="ex-panel" data-panel="1">
                        <div class="ex-card ex-card-top ex-card-teal">
                            <div class="ex-label">{t('practice_label_listen')}</div>
                            <div class="ex-speaker-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="#2DCCC2" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                            </div>
                        </div>
                        <div class="ex-card ex-card-bottom ex-card-teal">
                            <div class="ex-label">{t('practice_label_choose_translation')}</div>
                            <div class="ex-grid-2x2">
                                {optionList.map((opt, i) => (
                                    <div class={`ex-option${i === selectedIdx ? ' selected' : ''}`}>{opt}</div>
                                ))}
                            </div>
                        </div>
                        <div class="ex-action-btn ex-btn-teal">{t('practice_btn_check')}</div>
                    </div>

                    <div class="ex-panel" data-panel="2">
                        <div class="ex-card ex-card-top">
                            <div class="ex-word-sub">{wordLower}</div>
                        </div>
                        <div class="ex-card ex-card-bottom ex-card-teal">
                            <div class="ex-label">{t('practice_label_form_word')}</div>
                            <div class="ex-spell-input">{typedPrefix}<span class="ex-cursor">|</span></div>
                            <div class="ex-spell-divider"></div>
                            <div class="ex-letter-bubbles">
                                {usedChars.map((ch) => (
                                    <span class="letter-bubble used">{ch.toUpperCase()}</span>
                                ))}
                                {remainingChars.map((ch) => (
                                    <span class="letter-bubble">{ch.toUpperCase()}</span>
                                ))}
                            </div>
                        </div>
                        <div class="ex-action-btn ex-btn-inactive">{t('practice_btn_skip')}</div>
                    </div>

                    <div class="ex-panel" data-panel="3">
                        <div class="ex-card ex-card-top">
                            <div class="ex-word-main">{word.word}</div>
                        </div>
                        <div class="ex-card ex-card-bottom ex-card-teal">
                            <div class="ex-label">{t('practice_label_is_correct')}</div>
                            <div class="ex-word-answer">{opts.correct}</div>
                            <div class="ex-yesno-row">
                                <div class="ex-yesno-btn ex-btn-yes">{t('practice_btn_yes')}</div>
                                <div class="ex-yesno-btn ex-btn-no">{t('practice_btn_no')}</div>
                            </div>
                        </div>
                    </div>

                    <div class="ex-panel" data-panel="4">
                        <div class="ex-card ex-card-top">
                            <div class="ex-word-main">{word.word}</div>
                            {word.ipa && <div class="ex-ipa">{word.ipa}</div>}
                        </div>
                        <div class="ex-card ex-card-bottom ex-card-teal">
                            <div class="ex-label">{t('practice_label_press_speak')}</div>
                            <div class="ex-mic-btn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>
                            </div>
                            <div class="ex-mic-hint">{t('practice_label_better_silence')}</div>
                        </div>
                        <div class="ex-action-btn ex-btn-inactive">{t('practice_btn_skip')}</div>
                    </div>

                    <div class="ex-panel" data-panel="5">
                        <div class="ex-card ex-card-top">
                            <div class="ex-word-main">{word.word}</div>
                            {word.ipa && <div class="ex-ipa">{word.ipa}</div>}
                            <div class="ex-speaker-small">
                                <svg viewBox="0 0 24 24" fill="none" stroke="#2DCCC2" stroke-width="2" width="18" height="18"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
                            </div>
                        </div>
                        <div class="ex-card ex-card-bottom ex-card-teal ex-recall-prompt">
                            <div class="ex-label">{t('practice_label_whats_translation')}</div>
                        </div>
                        <div class="ex-action-btn ex-btn-teal">{t('practice_btn_show_translation')}</div>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="exercise-desc">
                <p class="ex-desc active" data-desc="0">{t('practice_desc_choose')}</p>
                <p class="ex-desc" data-desc="1">{t('practice_desc_listen')}</p>
                <p class="ex-desc" data-desc="2">{t('practice_desc_spell')}</p>
                <p class="ex-desc" data-desc="3">{t('practice_desc_is_correct')}</p>
                <p class="ex-desc" data-desc="4">{t('practice_desc_pronounce')}</p>
                <p class="ex-desc" data-desc="5">{t('practice_desc_recall')}</p>
            </div>
        </div>
    </div>
</section>

<style>
    .practice-section {
        padding: 80px 0;
    }

    .practice-header {
        text-align: center;
        max-width: 640px;
        margin: 0 auto 48px;
    }

    .practice-header h2 {
        margin-top: 16px;
        margin-bottom: 16px;
    }

    .practice-subtitle {
        color: var(--text-secondary, rgba(255, 255, 255, 0.7));
        font-size: 1.1rem;
        line-height: 1.7;
    }

    .practice-layout {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 40px;
        align-items: center;
    }

    /* === Exercise tabs (left) === */
    .exercise-tabs {
        display: flex;
        flex-direction: column;
        gap: 6px;
        justify-self: end;
    }

    .ex-tab {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        background: transparent;
        border: 1px solid transparent;
        border-radius: 14px;
        cursor: pointer;
        font-size: 0.92rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.4);
        transition: all 0.3s ease;
        white-space: nowrap;
        text-align: left;
    }

    .ex-tab:hover {
        color: rgba(255, 255, 255, 0.7);
        background: rgba(255, 255, 255, 0.03);
    }

    .ex-tab.active {
        color: #fff;
        background: rgba(45, 204, 194, 0.08);
        border-color: rgba(45, 204, 194, 0.25);
    }

    .ex-tab-icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        opacity: 0.4;
        transition: all 0.3s ease;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .ex-tab.active .ex-tab-icon {
        opacity: 1;
        stroke: #2DCCC2;
    }

    /* === Phone mockup (center) === */
    .phone-mockup {
        display: flex;
        justify-content: center;
    }

    .phone-bezel {
        width: 280px;
        min-height: 480px;
        background: #f8f8f8;
        border-radius: 36px;
        padding: 20px 16px 16px;
        box-shadow:
            0 24px 60px rgba(0, 0, 0, 0.4),
            0 0 0 2px rgba(255, 255, 255, 0.08),
            inset 0 1px 0 rgba(255, 255, 255, 0.3);
        display: flex;
        flex-direction: column;
        gap: 10px;
        position: relative;
    }

    /* Progress */
    .ex-progress {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 4px 4px;
    }

    .ex-progress-text {
        font-size: 0.7rem;
        color: #858693;
        white-space: nowrap;
    }

    .ex-progress-bar {
        flex: 1;
        height: 4px;
        background: #e0e0e0;
        border-radius: 2px;
        overflow: hidden;
    }

    .ex-progress-fill {
        width: 35%;
        height: 100%;
        background: #2DCCC2;
        border-radius: 2px;
    }

    /* Panels */
    .ex-panel {
        display: none;
        flex-direction: column;
        gap: 10px;
        flex: 1;
        animation: fadeInPanel 0.35s ease;
    }

    .ex-panel.active {
        display: flex;
    }

    @keyframes fadeInPanel {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Cards */
    .ex-card {
        background: #fff;
        border-radius: 20px;
        padding: 20px 16px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 80px;
    }

    .ex-card-top {
        flex: 1;
        position: relative;
    }

    .ex-card-bottom {
        flex: 1.5;
    }

    .ex-card-teal {
        border: 3px solid #2DCCC2;
    }

    /* Word display */
    .ex-word-main {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a2e;
    }

    .ex-word-sub {
        font-size: 1.4rem;
        font-weight: 600;
        color: #858693;
    }

    .ex-word-answer {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a1a2e;
        margin: 12px 0;
    }

    .ex-ipa {
        font-size: 0.85rem;
        color: #858693;
        margin-top: 4px;
    }

    .ex-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #2DCCC2;
        margin-bottom: 10px;
    }

    /* Frequency dots */
    .ex-freq {
        display: flex;
        gap: 3px;
        margin-top: 6px;
    }

    .freq-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #e0e0e0;
    }

    .freq-dot.active {
        background: #2DCCC2;
    }

    /* 2x2 Grid options */
    .ex-grid-2x2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        width: 100%;
    }

    .ex-option {
        padding: 12px 8px;
        border: 2px solid #2DCCC2;
        border-radius: 10px;
        text-align: center;
        font-size: 0.85rem;
        font-weight: 600;
        color: #2DCCC2;
        background: #fff;
    }

    .ex-option.selected {
        background: #2DCCC2;
        color: #fff;
    }

    /* Speaker icon */
    .ex-speaker-icon {
        width: 48px;
        height: 48px;
        margin: 8px auto;
    }

    .ex-speaker-icon svg {
        width: 100%;
        height: 100%;
    }

    .ex-speaker-small {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
    }

    /* Spell letters */
    .ex-spell-input {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a1a2e;
        letter-spacing: 2px;
        min-height: 36px;
    }

    .ex-cursor {
        color: #2DCCC2;
        animation: blink 1s step-end infinite;
    }

    @keyframes blink {
        50% { opacity: 0; }
    }

    .ex-spell-divider {
        width: 100%;
        height: 2px;
        background: #2DCCC2;
        margin: 8px 0 12px;
    }

    .ex-letter-bubbles {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .letter-bubble {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        font-weight: 700;
        border: 2px solid #2DCCC2;
        color: #fff;
        background: #2DCCC2;
        cursor: pointer;
    }

    .letter-bubble.used {
        background: #fff;
        color: #2DCCC2;
    }

    /* Yes/No */
    .ex-yesno-row {
        display: flex;
        gap: 10px;
        width: 100%;
    }

    .ex-yesno-btn {
        flex: 1;
        padding: 12px;
        border-radius: 10px;
        text-align: center;
        font-size: 0.9rem;
        font-weight: 700;
        color: #fff;
    }

    .ex-btn-yes {
        background: #2DCCC2;
    }

    .ex-btn-no {
        background: #2DCCC2;
    }

    /* Microphone */
    .ex-mic-btn {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #2DCCC2;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 12px auto;
        box-shadow: 0 4px 16px rgba(45, 204, 194, 0.3);
    }

    .ex-mic-btn svg {
        width: 28px;
        height: 28px;
    }

    .ex-mic-hint {
        font-size: 0.75rem;
        color: #858693;
        font-style: italic;
    }

    /* Recall prompt */
    .ex-recall-prompt {
        flex: 1;
        justify-content: center;
    }

    /* Action buttons */
    .ex-action-btn {
        padding: 14px;
        border-radius: 14px;
        text-align: center;
        font-size: 0.9rem;
        font-weight: 700;
        color: #fff;
    }

    .ex-btn-teal {
        background: #2DCCC2;
    }

    .ex-btn-inactive {
        background: transparent;
        border: 2px solid #CACBE1;
        color: #CACBE1;
    }

    /* === Description (right) === */
    .exercise-desc {
        justify-self: start;
        min-height: 60px;
        display: flex;
        align-items: center;
    }

    .ex-desc {
        color: var(--text-secondary, rgba(255, 255, 255, 0.7));
        font-size: 1rem;
        line-height: 1.6;
        max-width: 280px;
        margin: 0;
        display: none;
    }

    .ex-desc.active {
        display: block;
        animation: fadeInPanel 0.35s ease;
    }

    /* === Responsive === */
    @media (max-width: 1024px) {
        .practice-layout {
            grid-template-columns: 1fr auto;
            gap: 32px;
        }

        .exercise-desc {
            display: none;
        }

        .exercise-tabs {
            justify-self: stretch;
        }
    }

    @media (max-width: 768px) {
        .practice-section {
            padding: 48px 0;
        }

        .practice-layout {
            grid-template-columns: 1fr;
            gap: 24px;
        }

        .phone-mockup {
            order: -1;
        }

        .phone-bezel {
            width: 260px;
            min-height: 420px;
            padding: 16px 12px 12px;
        }

        .exercise-tabs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6px;
        }

        .ex-tab {
            padding: 10px 14px;
            font-size: 0.82rem;
        }
    }
</style>

<script>
  const exTabs = document.querySelectorAll('.practice-section .ex-tab');
  const exPanels = document.querySelectorAll('.practice-section .ex-panel');
  const exDescs = document.querySelectorAll('.practice-section .ex-desc');

  function setExercise(index: number) {
    exTabs.forEach((t, i) => t.classList.toggle('active', i === index));
    exPanels.forEach((p, i) => p.classList.toggle('active', i === index));
    exDescs.forEach((d, i) => d.classList.toggle('active', i === index));
  }

  exTabs.forEach((tab, i) => {
    tab.addEventListener('click', () => setExercise(i));
  });

  // Auto-cycle
  let exCurrent = 0;
  let exAuto = setInterval(() => {
    exCurrent = (exCurrent + 1) % exTabs.length;
    setExercise(exCurrent);
  }, 4000);

  const phoneEl = document.querySelector('.phone-bezel');
  phoneEl?.addEventListener('mouseenter', () => clearInterval(exAuto));
  phoneEl?.addEventListener('mouseleave', () => {
    exAuto = setInterval(() => {
      exCurrent = (exCurrent + 1) % exTabs.length;
      setExercise(exCurrent);
    }, 4000);
  });

  // Sync tab click with auto-cycle
  exTabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      exCurrent = i;
      clearInterval(exAuto);
      exAuto = setInterval(() => {
        exCurrent = (exCurrent + 1) % exTabs.length;
        setExercise(exCurrent);
      }, 4000);
    });
  });
</script>
